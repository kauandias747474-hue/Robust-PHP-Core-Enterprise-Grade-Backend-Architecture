# --- CORE CONFIG (Para as 120 linhas do Autoloader) ---
# Define a raiz do projeto para o PSR-4
APP_BASE_PATH="/var/www/html/kernel"
NAMESPACE_ROOT="App\\"

# --- SYSTEM SHIELD (Para as 39 linhas do Security Error) ---
# Se 'false', o escudo esconde erros técnicos do usuário final
APP_DEBUG=true
# Caminho para o despejo de logs caso o sistema falhe
LOG_DIRECTORY="./storage/logs"

# --- CONFIG ECHO (Para as 49 linhas do Config Echo) ---
# Variáveis que o seu motor de 49 linhas vai injetar no sistema
DB_HOST=localhost
DB_PORT=3306
DB_NAME=core_db
DB_USER=admin
DB_PASS=secret_token_777
